{
  "name": "@tinacms/starter",
  "version": "0.1.0",
  "private": true,
  "resolutions": {
    "better-sqlite3": "8.6.0"
  },
  "overrides": {
    "better-sqlite3": "8.6.0"
  },
  "pnpm": {
    "overrides": {
      "better-sqlite3": "8.6.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "tinacms dev -c \"next dev\"",
    "prebuild": "node -e \"const fs=require('fs'); const path=require('path'); const dir='node_modules/better-sqlite3/build/Release'; if(fs.existsSync(path.join(dir, 'better_sqlite3.node'))) { fs.mkdirSync('native-bindings', { recursive: true }); fs.copyFileSync(path.join(dir, 'better_sqlite3.node'), 'native-bindings/better_sqlite3.node'); }\"",
    "build": "tinacms build && next build",
    "build-local": "tinacms build --local --skip-indexing --skip-cloud-checks && next build",
    "start": "tinacms build && next start",
    "export": "npm run build && next export",
    "lint": "next lint",
    "dev:build": "next build"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tinacms/cli": "^1.9.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/styled-components": "^5.1.34",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.4",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tinacms/auth": "^1.0.11",
    "better-sqlite3": "8.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.479.0",
    "mermaid": "^11.4.1",
    "next": "^14.2.24",
    "next-themes": "^0.4.4",
    "next-tinacms-cloudinary": "^13.0.2",
    "nuqs": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-player": "^2.16.0",
    "styled-jsx": "^5.1.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tinacms": "^2.7.2",
    "usehooks-ts": "^3.1.1",
    "zustand": "^5.0.3"
  }
}
